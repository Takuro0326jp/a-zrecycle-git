/* ページトップ */
#page-top { text-align:right; padding: 0 0 10px 0; font-size: 110%; font-family: Helvetica, Arial; }
@media screen and (max-width: 768px) {
	#page-top { float: none; position: fixed; bottom: 50px; right: 20px; }
	#page-top a { background: rgba( 31, 20, 16, .6); text-decoration: none; color: #fff; width: 100px; padding: 12px 6px; text-align: center; display: block; border-radius: 5px; }
	#page-top a:hover { text-decoration: none; background:  rgba( 31, 20, 16, .8); }
}

@media screen and (max-width: 768px) {
	#page-top { bottom: 0px; right: 10px; }
}


