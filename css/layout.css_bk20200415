/* printPreferenceForFirefox */
@media print {
	#contents-area, x:-moz-any-link { clear: none; padding-top: 10px; }
	#contents-area-box, x:-moz-any-link { clear: none; display: table; direction: rtl;text-align:left; }
	#contents-area-box *, x:-moz-any-link { direction: ltr; }
	#main, x:-moz-any-link{ display:table-cell; float:none; vertical-align:top; padding: 0 10px; }
	.side-left-parts, x:-moz-any-link{ display:table-cell; float:none; vertical-align:top;}
	#side-right-box, x:-moz-any-link{ display:table-cell; float:none; vertical-align:top;}
}
