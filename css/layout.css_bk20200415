/* ----- SIDE ----- */
.sidebar { width: 210px; font-size: 1.4em; overflow: hidden; }

.side-left-parts{ float: left; }
#side-right-box{ width: 210px; float: right; }
#side-right-parts{  }
#side-right-box-wp{ width: 210px; float: right; }

@media screen and (max-width: 768px) {
	#side-right-box{ width: 96%; float: none; margin: 0 auto; }
	#side-right-parts{ float: right; }
}
@media screen and (max-width: 480px) {
	.side-left-parts{ float: none; width: 210px; margin: 0 auto; }
	#side-right-box{ clear: both; width: 210px; }
	#side-right-parts{ float: none; }
	#side-right-box-wp{ float: none; margin: 0 auto; width: 96%; }
}



