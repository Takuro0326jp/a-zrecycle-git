@charset "utf-8";
/* CSS Document */

/* base
------------------------------------------------------------------------------------------------ */
html {
	margin: 0px !important;
	padding: 0px !important;
}
body, div, dl, dt, dd, ul, ol, li, h1, h2, h3, h4, h5, h6, form, input, p, blockquote, th, td { margin:0; padding:0; }
body { color:#333; font: 62.5%/1.4 "ＭＳ Ｐゴシック", Osaka, "ヒラギノ角ゴ Pro W3", sans-serif; margin: 0 auto; }

img { max-width: 100%; width: auto\9; /* ie8 */ height: auto; border:0; vertical-align: top; }


a:link {color:#191919;text-decoration: underline;}
a:visited {color: #191919;text-decoration: underline;}
a:hover {color: #191919; text-decoration: none; }
.a-img a:hover img{opacity:0.6; filter: alpha(opacity=60); }

/*clearfix*/
.clearfix:after { display: block; visibility:hidden; clear: both; height:0; content: " "; font-size: 0; }
* html .clearfix { zoom: 1; } /* IE6 */
*:first-child+html .clearfix { zoom: 1; } /* IE7 */

/* pc-nonpc_switch  */
.pc { display:block; }/*pcのみ表示*/
.nonpc { display: none; }/*pc非表示、tablet,smartphoneで表示*/
.pc-tablet { display: block; }/* PC,tabletで表示 */
.pc-tablet-inline { display: inline; }/* PC,tabletで表示 */
.nonpc-small { display: none; }/* smartphoneのみ表示*/
.nonpc-small-inline { display: none; }/* smartphoneのみ表示*/
.tablet { display:none; }/* tabletのみ表示*/

@media screen and (max-width: 768px) {
	.pc { display:none; }/*pcのみ表示*/
	.nonpc { display:block; }/*pc非表示、tablet,smartphoneで表示*/
	.pc-tablet { display: block; }/* PC,tabletで表示 */
	.pc-tablet-inline { display: inline; }/* PC,tabletで表示 */
	.nonpc-small { display: none; }/* smartphoneのみ表示*/
	.nonpc-small-inline { display: none; }/* smartphoneのみ表示*/
	.tablet { display:block; }/* tabletのみ表示*/
}

@media screen and (max-width: 480px) {
	.pc { display:none; }/*pcのみ表示*/
	.nonpc { display:block; }/*pc非表示、tablet,smartphoneで表示*/
	.pc-tablet { display: none; }/* PC,tabletで表示 */
	.pc-tablet-inline { display: none; }/* PC,tabletで表示 */
	.nonpc-small { display: block; }/* smartphoneのみ表示*/
	.nonpc-small-inline { display: inline; }/* smartphoneのみ表示*/
	.tablet { display:none; }/* tabletのみ表示*/
}



/* 全体を含むボックス：100%とする */
#page { width: 100%; }



/* ---------------------------------------------------------------------------------------------
HEADER
------------------------------------------------------------------------------------------------ */

#header-box { width: 990px; margin: 0 auto;}

/* top,header-parts */
#top { font-size:11px; margin: 0;font-weight: normal; padding: 4px 0 4px 0; border-bottom: 1px solid #949392;}
#top-catch{ padding-left: 1em; margin-bottom: 6px;}
#header-logo{ float: left; }
#header-mail{ float: left; margin: 10px 10px 0 240px; }
#header-phone{ float: right; margin: 10px 0 0 0; }
@media screen and (max-width: 768px) {
	#header-box { width: 96%; }
	#header-logo{ max-width: 190px; width: 20%; }
	#header-mail{ max-width: 272px; width: 40%; margin-left: 6%; }
	#header-phone{ max-width: 208px; width: 30%; }
}
@media screen and (max-width: 480px) {
	#header-logo{ max-width: none; width: 100%; text-align: center; }
	#header-mail{ max-width: none; width: 46%; margin-left: 2%; }
	#header-phone{ max-width: none; width: 46%; }
}


/* Global navi */
#gnavi-box { width: 990px; height: 45px; clear: both; margin: 0 auto 30px; border: 1px solid #FFF; }
#gnavi { width: 100%; margin-top: 10px; }
#gnavi ul { overflow: hidden; list-style: none; }
#gnavi li { float: left; width: 180px; height: 35px; }
#gnavi li a { display: block; }

#gnavi-1{ margin-right: 18px; background: url(../images/cmn/gnavi_home_bg.gif) no-repeat bottom right; }
#gnavi-2{ margin-right: 18px; background: url(../images/cmn/gnavi_purchase_bg.gif) no-repeat bottom right; }
#gnavi-3{ margin-right: 9px; margin-left: 9px; background: url(../images/cmn/gnavi_qna_bg.gif) no-repeat bottom right; }
#gnavi-4{ margin-left: 18px; background: url(../images/cmn/gnavi_voice_bg.gif) no-repeat bottom right; }
#gnavi-5{ margin-left: 18px; background: url(../images/cmn/gnavi_about_bg.gif) no-repeat bottom right; }

@media screen and (max-width: 768px) {
	#gnavi-box { width: 98%; margin: 0 1% 30px; }
	#gnavi li { width: 22%; max-width: 180px; }
	#gnavi-1{ display: none; }
	#gnavi-2{ margin-right: 2%; }
	#gnavi-3{ margin-right: 1%; margin-left: 1%; }
	#gnavi-4{ margin-right: 1%; margin-left: 1%; }
	#gnavi-5{ margin-left: 2%; }
}
@media screen and (max-width: 480px) {
	#gnavi-box { margin-bottom: 14px; height: auto; }
	#gnavi li { height: 26px; }
}

/* head_mainnavi */
#head { width: 990px; height: 300px; margin: 0 auto; background: url(../images/cmn/head_bg.jpg) no-repeat;}
#head-catch { font-size: 1.3em; }
#mainnavi-ttl{ float: right; margin: 10px 20px 10px 0; width: 270px; }
#head ul { list-style: none; width: 270px; float: right; margin: 0 20px 0 0; clear: both; }
#head ul li { margin-bottom: 4px; }
#head-m{ display: none; }
#head-s{ display: none; }

@media screen and (max-width: 768px) {
	#head { height: 0; width: 100%; background-size: 100% auto; padding-bottom: 30.3%; }
	#mainnavi-ttl{ width: 26%; }
	#head ul { width: 26%; }
}
@media screen and (max-width: 550px) {
	#head { width: 100%; height: auto; background: none; padding-bottom: 0; }
	#head-m{ display: block; }
	#mainnavi-ttl{ float: none; width: 270px; margin: 10px auto; }
	#head ul { float: none; width: 270px; margin: 10px auto; }
}
@media screen and (max-width: 480px) {
	#head { width: 300px; }
	#head-m{ display: none; }
	#head-s{ display: block; }
	#mainnavi-ttl{ float: none; margin: 10px auto ; }
}

#mainnavi-img{ text-align: center; margin-bottom: 15px; }
#mainnavi-img #mainnavi-ttl{ float: none; width: 100%; margin: 10px 0; }
#mainnavi-img ul{ list-style: none; clear: both; overflow: hidden; width: 100%; height: auto; }
#mainnavi-img li{ float: left; width: 33%; }
@media screen and (max-width: 480px) {
	#mainnavi-img li{ float: none; margin-bottom: 4px; width: 100%; }
}

/* ---------------------------------------------------------------------------------------------
CONTENTS_LAYOUT
------------------------------------------------------------------------------------------------ */
/* contents = main + side */

#contents-area { clear: both; margin: 0 auto; width: 990px; overflow: hidden;  }
#contents-box { overflow: hidden; padding: 20px 0 0 0; width: 990px; }
@media screen and (max-width: 768px) {
	#contents-area { width: 96%; }
	#contents-box { width: 530px; margin: 0 auto; }
}
@media screen and (max-width: 550px) {
	#contents-box { width: 96%; }
	#sidebarxx{ float: right; }
}
@media screen and (max-width: 480px) {
	#contents-area { width: 100%; }
	#contents-box { width: 300px; }
	#sidebarxx{ float: none; }
}

/* ----- MAIN ----- */
#main { width: 530px; height: 100%; font-size: 1.4em; overflow: hidden; float: left; margin-left: 20px; }
#main p { margin-bottom: 1em; }
@media screen and (max-width: 768px) { #main { margin: 0 auto 60px auto; } }
@media screen and (max-width: 550px) { #main { margin: 15px auto 30px 0; width: 100%; } }
@media screen and (max-width: 480px) { #main { margin-top: 0;  } }


