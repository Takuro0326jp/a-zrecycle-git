.bottom_banner {
	position: relative;
	width: 812px;
	height: 38px;
	background: #FFF;
	border: 1px solid #000;
	margin: 25px auto;
}
.bottom_banner div{
	width: 800px;
	height: 26px;
	background: #D66A07;
	margin: 2px;
	padding: 4px;
}
.bottom_banner img{
	margin: 5px 0 0 15px;

}
.bottom_banner p {
	font-size: 17px;
	font-weight: bold;
	letter-spacing: -0.05em;
	text-align: center;
	color: #fff;
	padding-top: 7px;
}
.bottom_banner a {
	text-decoration: none;
	position: absolute;
	top: 0;
	left: 0;
	width: 100%;
	height: 100%;
}

@media screen and (max-width: 768px) {
	.bottom_banner { width: 660px; }
	.bottom_banner div{ width: 648px; }
	.bottom_banner img{ width: 290px;height: auto; margin-top: 8px; }
	.bottom_banner p { width: 340px; float: right;font-size: 16px; }
}
@media screen and (max-width: 680px) {
	.bottom_banner { width: 500px; }
	.bottom_banner div{ width: 488px; }
	.bottom_banner img{ width: 200px;height: auto; margin-top: 10px; }
	.bottom_banner p { font-size: 13px; width: 280px; margin-top: 2px; }
}
@media screen and (max-width: 530px) {
	.bottom_banner { clear: both; width: 300px; height: 58px; }
	.bottom_banner div{ width: 288px; height: 46px; }
	.bottom_banner img{ width: 288px;margin: 10px 0 0 5px; }
	.bottom_banner p { clear: both; width: 100%; margin-top: 0;padding-top: 4px; }
}

/* blog *****************/
div#content div.article .articleHead { width: 380px; }



/* SITEMAP ----------------------------------------------- */
#ul-sitemap { margin: 10px 0 0 10px; }
#ul-sitemap dt{ font-weight: bold; margin-bottom: .2em; }
#ul-sitemap dd{ margin-left: 2em; margin-bottom: 2em; }
#ul-sitemap ul{ margin: .4em 0 1.2em 1em; list-style: none; }
#ul-sitemap ul li{ background: url(../images/sitemap_ul_bg.gif) no-repeat 0 2px; padding-left: 20px; margin-bottom: .4em; }




/* 2016.08.09 top-information 追加
**********************************/
.top-information {
	-webkit-box-sizing: border-box;
	-moz-box-sizing: border-box;
	box-sizing: border-box;
	width: 94%;
	font-size: 14px;
	padding: 17px;
	border: 3px solid #c00;
	margin: 20px auto 0;
}

.top-information h3 {
	font-weight: bold;
	margin-bottom: 5px;
}

@media only screen and (min-width:770px) {
	.top-information {
		width: 100%;
	}
}
@media screen and (max-width: 768px) {
	.form_tel{
		display: none;
	}
	.sp_form_tel{
		transition: all 0.3s ease-in-out;
		bottom: 0;
		left: 0;
		position: fixed;
		display: block;
		width: 100%;
		padding: 10px 0;
		z-index: 999;
		background-color: rgba(255,255,255,.8);
	}
	.sp_form_tel.bottom_fix{
		transition: all 0.3s ease-in-out;
		bottom: -9999%;
	}
	.sp_form_tel a{
		display: block;
		border-radius: 5px;
		background-color: #e07e01;
		color: #fff;
		padding: 15px 10px;
		margin: 0 auto;
		width: 90%;
		font-size: 14px;
		text-decoration: none;
		text-align: center;
	}
	.sp_form_tel a img{
		display: inline-block;
		width: 22px;
		height: auto;
		margin-right: 10px;
		vertical-align: sub;
	}
}
@media screen and (min-width: 769px) {
	.form_tel{
		position: fixed;
		display: inline-block;
		bottom: 2%;
		padding: 15px;
		right: 1%;
		background-color: #fff;
		transition: all .4s ease-in;
	}
	.form_tel.bottom_fix{
		position: fixed;
		display: inline-block;
		bottom: -9999px;
		padding: 15px;
		right: 1%;
		background-color: #fff;
		transition: all .4s ease-in;
	}
	.sp_form_tel{
		display: none;
	}
}
