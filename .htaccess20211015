php_value max_execution_time 120
php_value post_max_size 120M
php_value upload_max_filesize 100M

Options +FollowSymLinks
RewriteCond %{THE_REQUEST} ^.*/index.html
RewriteRule ^(.*)index.html$ https://www.a-zrecycle.com/$1 [R=301,L]

<IfModule mod_rewrite.c>
  RewriteEngine on
  RewriteCond %{HTTPS} !on
  RewriteRule (.*) https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

  RewriteEngine on
  RewriteRule ^brand/page(.*)$ /brand [L,R=301]

  RewriteEngine on
  RewriteRule ^products/page(.*)$ /products [L,R=301]

  RewriteEngine On
  RewriteRule ^purchase/(.*)\.html/(.*)$ - [R=404,L]

  RewriteEngine On
  RewriteRule ^about/(.*)\.html/(.*)$ - [R=404,L]
</IfModule>

